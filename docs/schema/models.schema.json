{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cognovis/cognovis-library/docs/schema/models.schema.json",
  "title": "Library Agent Model Registry",
  "type": "object",
  "required": ["version", "models"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "harness",
          "tier",
          "reasoning_levels",
          "context",
          "vision",
          "cost"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "harness": {
            "type": "string",
            "enum": ["claude-code", "codex", "opencode", "pi"]
          },
          "tier": {
            "type": "string",
            "enum": ["economy", "standard", "premium", "frontier"]
          },
          "reasoning_levels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["low", "medium", "high", "xhigh", "max"]
            },
            "uniqueItems": true
          },
          "default_reasoning": {
            "type": "string",
            "enum": ["low", "medium", "high", "xhigh", "max"]
          },
          "context": {
            "type": "string",
            "enum": ["small", "medium", "large"]
          },
          "vision": {
            "type": "boolean"
          },
          "cost": {
            "type": "object",
            "required": ["input", "output"],
            "additionalProperties": false,
            "properties": {
              "input": {
                "type": "number",
                "minimum": 0
              },
              "output": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
