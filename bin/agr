#!/usr/bin/env zsh
# agr - Antigravity launcher with automatic approvals
#
# Usage: agr [wrapper-flags] [agy-args...]
#        agr -h | --help        Show wrapper flag help, then fall through to agy --help
#
# Wrapper flags (not passed to agy):
#   --skip-perms-off → Launch agy without the default --dangerously-skip-permissions wrapper
#
# Per AGENTS.md: launchers live in bin/

set -euo pipefail

# Auto-detect agy binary
AGY_BIN="${AGY_BIN:-$(command -v agy 2>/dev/null)}"
if [[ -z "${AGY_BIN}" ]]; then
    echo "ERROR: agy not found in PATH. Install Antigravity CLI first."
    exit 1
fi

# ── Parse wrapper flags ──────────────────────────────────────────

use_skip_perms=true
show_help=false
agy_args=()

while (( $# > 0 )); do
    case "$1" in
        -h|--help)
            show_help=true
            shift
            ;;
        --skip-perms-off)
            use_skip_perms=false
            shift
            ;;
        *)
            agy_args+=("$1")
            shift
            ;;
    esac
done

# ── Help ──────────────────────────────────────────────────────────

if ${show_help}; then
    cat <<'HELP'
agr - Antigravity launcher with automatic approvals

Usage: agr [wrapper-flags] [agy-args...]

Wrapper flags (consumed by agr, not passed to agy):

  Session:
         --skip-perms-off        Launch agy without the default --dangerously-skip-permissions flag
    -h,  --help                  Show this help, then agy --help

────────────────────────────────────────────────────────────
Forwarding to 'agy --help':
HELP
    exec "${AGY_BIN}" --help
fi

# ── Default: plain agy launch with dangerously-skip-permissions ───

if ${use_skip_perms}; then
    exec "${AGY_BIN}" --dangerously-skip-permissions "${agy_args[@]}"
else
    exec "${AGY_BIN}" "${agy_args[@]}"
fi
