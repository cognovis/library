#!/usr/bin/env zsh
# cra - Cursor Agent launcher (approvals on by default; --yolo to auto-approve)
#
# Usage: cra [wrapper-flags] [agent-args...]
#        cra -h | --help        Show wrapper flag help, then fall through to agent --help
#
# Wrapper flags (not passed to agent):
#   --yolo          → explicit opt-in: forward --yolo to agent (disables approval
#                     prompts; overrides the safe default; prints a warning)
#   --no-yolo       → no-op (yolo is off by default); kept for backward compatibility
#
# Per AGENTS.md: launchers live in bin/

set -euo pipefail

# Auto-detect agent binary
AGENT_BIN="${AGENT_BIN:-$(command -v agent 2>/dev/null)}"
if [[ -z "${AGENT_BIN}" ]]; then
    # Fallback to ~/.local/bin/agent
    if [[ -x "${HOME}/.local/bin/agent" ]]; then
        AGENT_BIN="${HOME}/.local/bin/agent"
    else
        echo "ERROR: agent not found in PATH. Install Cursor Agent first."
        exit 1
    fi
fi

# ── Parse wrapper flags ──────────────────────────────────────────

use_yolo=false
show_help=false
agent_args=()

while (( $# > 0 )); do
    case "$1" in
        -h|--help)
            show_help=true
            shift
            ;;
        --yolo)
            use_yolo=true
            shift
            ;;
        --no-yolo)
            use_yolo=false
            shift
            ;;
        *)
            agent_args+=("$1")
            shift
            ;;
    esac
done

# ── Help ──────────────────────────────────────────────────────────

if ${show_help}; then
    cat <<'HELP'
cra - Cursor Agent launcher (approvals on by default; --yolo to auto-approve)

Usage: cra [wrapper-flags] [agent-args...]

Wrapper flags (consumed by cra, not passed to agent):

  Session:
         --yolo                  Explicit opt-in: forward --yolo to agent
                                (disables approval prompts; prints a warning)
         --no-yolo               No-op (yolo is off by default); kept for
                                backward compatibility
    -h,  --help                  Show this help, then agent --help

────────────────────────────────────────────────────────────
Forwarding to 'agent --help':
HELP
    exec "${AGENT_BIN}" --help
fi

# ── Default: safe launch; --yolo requires explicit opt-in ─────────

if ${use_yolo}; then
    echo -e "\033[0;33mWARNING: --yolo selected; forwarding --yolo to agent (disables approval prompts, no safety confirmations).\033[0m" >&2
    exec "${AGENT_BIN}" --yolo "${agent_args[@]}"
else
    exec "${AGENT_BIN}" "${agent_args[@]}"
fi
