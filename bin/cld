#!/usr/bin/env zsh
# cld - Claude Code launcher with beads workflow integration
#
# Usage: cld [wrapper-flags] [claude-args...]
#        cld -h | --help        Show wrapper flag help, then fall through to claude --help
#
# Wrapper flags (not passed to claude):
#   --skip-perms    → translates to --dangerously-skip-permissions (overrides default auto mode)
#   -v, --verbose   → enable verbose mode (reasoning traces + token counts)
#   -c, --caveman   → enable caveman mode for this session (exports CAVEMAN_MODE=1)
#   -b, --bead ID   → launch with bead orchestrator for the given bead ID
#                     (refuses if ID has children)
#   -bq, --bead-quick ID → launch with quick-fix agent for XS/S beads (bug, chore, task)
#   -br, --bead-review ID → launch critical bead-spec/readiness review
#   --coordinator-workspace workspace:<n> → coordinator callback workspace ref
#   --coordinator-surface surface:<n> → coordinator callback surface ref
#   -bp, --plan-label LABEL → launch with /plan --label LABEL as initial prompt
#   --route-profile NAME → select named route profile (exports CLD_ROUTE_PROFILE)
#   --force-tier TIER → force routing tier (e.g. mcp, infra); passed to phase0-claim.py
#                          profiles: cld-default (default for -bq), cld-composer, cdx-default, cdx-composer

set -uo pipefail

# Auto-detect claude binary
CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude 2>/dev/null)}"
if [[ -z "${CLAUDE_BIN}" ]]; then
    echo "ERROR: claude not found in PATH. Install Claude Code first."
    exit 1
fi

BD_BIN="${BD_BIN:-$(command -v bd 2>/dev/null)}"

# ── Parse wrapper flags ──────────────────────────────────────────

caveman=false
skip_perms=false
verbose=false
bead_id=""
bead_quick_id=""
bead_review_id=""
coordinator_workspace=""
coordinator_surface=""
route_profile=""
force_tier=""
plan_label=""
show_help=false
claude_args=()

while (( $# > 0 )); do
    case "$1" in
        -h|--help)
            show_help=true
            shift
            ;;
        -c|--caveman)
            caveman=true
            shift
            ;;
        --skip-perms)
            skip_perms=true
            shift
            ;;
        -v|--verbose)
            verbose=true
            shift
            ;;
        -b|--bead)
            bead_id="$2"
            shift 2
            ;;
        -bq|--bead-quick)
            bead_quick_id="$2"
            shift 2
            ;;
        -br|--bead-review)
            bead_review_id="${2:-}"
            if [[ -z "$bead_review_id" ]]; then
                echo "ERROR: -br requires a bead id" >&2
                exit 2
            fi
            shift 2
            ;;
        -bp|--plan-label)
            plan_label="$2"
            shift 2
            ;;
        --coordinator-workspace)
            coordinator_workspace="${2:-}"
            if [[ -z "$coordinator_workspace" ]]; then
                echo "ERROR: --coordinator-workspace requires an argument" >&2
                exit 2
            fi
            shift 2
            ;;
        --coordinator-surface)
            coordinator_surface="${2:-}"
            if [[ -z "$coordinator_surface" ]]; then
                echo "ERROR: --coordinator-surface requires an argument" >&2
                exit 2
            fi
            shift 2
            ;;
        -bw|--bead-wave|-bl|--bead-label|-bi|--bead-ids)
            echo "ERROR: cld does not dispatch multi-bead waves." >&2
            echo "Start wave orchestration manually, then use the wave skills with cmux panes." >&2
            echo "Use cld -b <bead-id> to implement exactly one bead." >&2
            exit 2
            ;;
        --route-profile)
            route_profile="$2"
            shift 2
            ;;
        --force-tier)
            force_tier="$2"
            shift 2
            ;;
        *)
            claude_args+=("$1")
            shift
            ;;
    esac
done

# ── Help: print wrapper flags, then fall through to claude --help ─
if ${show_help}; then
    cat <<'EOF'
cld - Claude Code launcher with beads workflow integration

Usage: cld [wrapper-flags] [claude-args...]

Wrapper flags (consumed by cld, not passed to claude):

  Bead workflows:
    -b,  --bead ID              Launch bead-orchestrator for single bead
                                (refuses if ID has children)
    -bq, --bead-quick ID        Launch quick-fix agent (XS/S beads)
    -br, --bead-review ID       Fresh-context critical bead-spec/readiness review
                                (uses bead-reviewer skill; defaults to --model opus)
    -bp, --plan-label LABEL     Launch with /plan --label LABEL
         --coordinator-workspace workspace:<n>
                                Coordinator callback workspace ref (requires surface)
         --coordinator-surface surface:<n>
                                Coordinator callback surface ref (requires workspace)
         --route-profile NAME    Select named route profile (exports CLD_ROUTE_PROFILE)
         --force-tier TIER       Force the routing tier (e.g. mcp, infra); passed to phase0-claim.py
                                Profiles: cld-default (default for -bq), cld-composer, cdx-default, cdx-composer

  Session:
    -c,  --caveman              Enable caveman mode (CAVEMAN_MODE=1)
    -v,  --verbose              Pass --verbose to claude
         --skip-perms           Use --dangerously-skip-permissions
    -h,  --help                 Show this help, then claude --help

────────────────────────────────────────────────────────────
Forwarding to 'claude --help':
EOF
    exec "${CLAUDE_BIN}" --help
fi

if [[ -n "$bead_review_id" && ( -n "$bead_id" || -n "$bead_quick_id" ) ]]; then
    echo "ERROR: -br/--bead-review is mutually exclusive with -b/--bead and -bq/--bead-quick" >&2
    exit 2
fi

if [[ ( -n "$coordinator_workspace" && -z "$coordinator_surface" ) || ( -z "$coordinator_workspace" && -n "$coordinator_surface" ) ]]; then
    echo "ERROR: coordinator callback requires both --coordinator-workspace and --coordinator-surface" >&2
    exit 2
fi

if [[ -n "$coordinator_workspace" && ! "$coordinator_workspace" =~ ^workspace:[0-9]+$ ]]; then
    echo "ERROR: invalid coordinator workspace '$coordinator_workspace' (expected workspace:<n>)" >&2
    exit 2
fi

if [[ -n "$coordinator_surface" && ! "$coordinator_surface" =~ ^surface:[0-9]+$ ]]; then
    echo "ERROR: invalid coordinator surface '$coordinator_surface' (expected surface:<n>)" >&2
    exit 2
fi

# Export CAVEMAN_MODE if -c/--caveman was passed
if ${caveman}; then
    export CAVEMAN_MODE=1
fi

# Build final claude args — default to Claude permission auto unless explicitly bypassed
if ${skip_perms}; then
    echo -e "\033[0;33mWARNING: --skip-perms selected; forwarding --dangerously-skip-permissions to claude.\033[0m" >&2
    claude_args=("--dangerously-skip-permissions" "${claude_args[@]}")
elif [[ -n "$bead_review_id" ]]; then
    # dontAsk, not plan: --permission-mode plan was found (via multiple
    # independent live probes, CL-9knh) to categorically block MCP tool
    # execution even for tools explicitly present in --allowedTools. dontAsk
    # honors --allowedTools/--disallowedTools without that blanket block.
    claude_args=("--permission-mode" "dontAsk" "${claude_args[@]}")
else
    claude_args=("--permission-mode" "auto" "${claude_args[@]}")
fi

if ${verbose}; then
    claude_args=("--verbose" "${claude_args[@]}")
fi

# ── Orchestrator config pre-flight ───────────────────────────────
# Self-heal the global ~/.agents/orchestrator-config.yml from the canonical
# catalog source so it never silently drifts (CL-0w6e follow-up).
source "${0:A:h}/lib/orchestrator-config-sync.zsh"
_sync_orchestrator_config

# ── System Prompt Injection ──────────────────────────────────────
source "${0:A:h}/lib/cld-system-prompt.zsh"

_sp_registry_dir="${0:A:h}/../system-prompts"
_sp_registry="${_sp_registry_dir}/registry.yml"

if [[ -f "$_sp_registry" ]]; then
    _sp_result=$(_cld_resolve_system_prompt "$_sp_registry" "${PWD}")
    if [[ -n "$_sp_result" ]]; then
        # Wire format: "file:<relative-path> mode:<replace|append>"
        # Assumes no spaces in the filename (all paths are relative to registry dir)
        _sp_file="${_sp_result#file:}"
        _sp_file="${_sp_file% mode:*}"
        _sp_mode="${_sp_result##* mode:}"
        _sp_path="${_sp_registry_dir}/${_sp_file}"
        # Resolve to absolute path using python3 (portable; realpath -m is GNU-only)
        _sp_path_real=$(python3 -c "import os,sys; print(os.path.abspath(sys.argv[1]))" "$_sp_path" 2>/dev/null || echo "$_sp_path")
        _sp_registry_dir_real=$(python3 -c "import os,sys; print(os.path.abspath(sys.argv[1]))" "$_sp_registry_dir" 2>/dev/null || echo "$_sp_registry_dir")

        if [[ "$_sp_path_real" != "${_sp_registry_dir_real}/"* ]]; then
            echo "[cld] ERROR: System prompt file path escapes registry dir: $_sp_file" >&2
            # Skip injection — refuse path traversal attempt
        elif [[ ! -f "$_sp_path_real" ]]; then
            echo "[cld] ERROR: System prompt file not found: $_sp_path_real" >&2
            # Skip injection — continue without system prompt flag
        else
            _sp_path="$_sp_path_real"
            if [[ "$_sp_mode" == "replace" ]]; then
                claude_args=("--system-prompt-file" "$_sp_path" "${claude_args[@]}")
            elif [[ "$_sp_mode" == "append" ]]; then
                claude_args=("--append-system-prompt-file" "$_sp_path" "${claude_args[@]}")
            else
                echo "[cld] ERROR: Unknown system prompt mode: $_sp_mode (expected: replace or append)" >&2
            fi

            if [[ "$_sp_mode" == "replace" || "$_sp_mode" == "append" ]] && [[ "${CLD_DEBUG:-}" == "1" ]]; then
                echo "[cld] System prompt: ${_sp_file} (mode: ${_sp_mode})" >&2
            fi
        fi
    else
        if [[ "${CLD_DEBUG:-}" == "1" ]]; then
            echo "[cld] System prompt: none (no match, no default)" >&2
        fi
    fi
fi

# ── Auto-expand short bead IDs ──────────────────────────────────
# e.g. "oms3" → "mira-oms3" when issue_prefix is "mira"
if [[ -n "$bead_id$bead_quick_id$bead_review_id" && -z "${BD_BIN}" ]]; then
    echo "ERROR: bd not found in PATH. Install the beads CLI first."
    exit 1
fi

local bead_prefix=""
if [[ -n "${BD_BIN}" ]]; then
    bead_prefix=$("${BD_BIN}" config get issue_prefix 2>/dev/null || true)
fi

_expand_bead_id() {
    local id="$1"
    # Only expand short slugs (no hyphen). IDs containing a hyphen are
    # treated as already-qualified bead IDs (possibly with a non-default
    # prefix in multi-prefix projects) and passed through unchanged.
    if [[ -n "$bead_prefix" ]] && [[ "$id" != *-* ]]; then
        echo "${bead_prefix}-${id}"
    else
        echo "$id"
    fi
}

# Extract short name for display (strip prefix): "mira-oms3" → "oms3"
_bead_short() {
    local id="$1"
    if [[ -n "$bead_prefix" ]] && [[ "$id" == "${bead_prefix}-"* ]]; then
        echo "${id#${bead_prefix}-}"
    else
        echo "$id"
    fi
}

# Count children of a bead (0 if none / bead not found). Requires jq.
_bead_child_count() {
    local id="$1"
    if [[ -z "${BD_BIN}" ]]; then
        echo "0"
        return
    fi
    if ! command -v jq &>/dev/null; then
        echo "0"
        return
    fi
    # Index by the actual bead ID key. When bd cannot resolve the bead it
    # still emits {"schema_version": 1} on stdout — picking by key (rather
    # than to_entries[0]) avoids the false-positive "1 child" caused by
    # jq's `length` on a number returning |n|.
    "${BD_BIN}" show "$id" --children --json 2>/dev/null \
        | jq -r --arg id "$id" '(.[$id] // []) | length' 2>/dev/null \
        || echo "0"
}

_bead_exists() {
    local id="$1"
    local bead_json

    if [[ -z "${BD_BIN}" ]]; then
        return 1
    fi

    bead_json=$("${BD_BIN}" show "$id" --json 2>/dev/null) || return 1

    if command -v jq &>/dev/null; then
        printf '%s' "$bead_json" \
            | jq -e --arg id "$id" '
                if type == "array" then any(.[]; .id == $id)
                elif type == "object" then .id == $id
                else false
                end
            ' >/dev/null 2>&1
    else
        [[ -n "$bead_json" ]]
    fi
}

_bead_status() {
    local id="$1"
    local bead_json

    bead_json=$("${BD_BIN}" show "$id" --json 2>/dev/null) || return 1
    if command -v jq &>/dev/null; then
        printf '%s' "$bead_json" \
            | jq -r 'if type == "array" then (.[0].status // "") else (.status // "") end' 2>/dev/null
    else
        echo ""
    fi
}

_abort_missing_bead() {
    local id="$1"
    local launcher="$2"

    echo -e "\033[0;31m✗ ${id} was not found in this repository.\033[0m" >&2
    echo "  Aborting before launching ${launcher}; run this command from the project that owns the bead." >&2
    echo "  Current directory: ${PWD}" >&2
    echo "  Check with: bd show ${id}" >&2
    exit 2
}

_has_coordinator_callback() {
    [[ -n "$coordinator_workspace" && -n "$coordinator_surface" ]]
}

_coordinator_callback_contract() {
    local mode="$1"

    if [[ "$mode" == "review" ]]; then
        cat <<EOF
Coordinator callback: this session runs under a coordinator that owns cmux
${coordinator_workspace} / ${coordinator_surface}. This read-only review session has no Bash access, so it cannot signal the coordinator directly:
- Emit your complete verdict as your final output, then end your turn normally. If you hit a genuine blocking question requiring a human decision before you can reach a verdict, emit that question with its full context instead, then end your turn normally.
- The launcher automatically runs cmux trigger-flash --surface ${coordinator_surface} once this session exits — you do not need to, and cannot, run it yourself.
- Normal progress updates are NOT terminal state and do not need special handling — just keep working until you reach a verdict or a genuine blocking question.
- Keep the COMPLETE verdict or question (with its full context) visible in this pane; do not clear or truncate it.
EOF
        return
    fi

    cat <<EOF
Coordinator callback: this session runs under a coordinator that owns cmux
${coordinator_workspace} / ${coordinator_surface}. Best-effort signaling contract:
- On a genuine blocking question or a required human decision, run:
  cmux trigger-flash --surface ${coordinator_surface}
  then keep the COMPLETE question and its full context visible in this pane
  (do not clear or truncate it).
- On terminal state, run:
  cmux trigger-flash --surface ${coordinator_surface}
  then keep the COMPLETE terminal report visible in this pane.
- Implementation terminal state includes successful OR failed completion of Phase 16
  session-close. Carry this callback contract into the Phase 16 session-close handoff
  so the terminal signal fires there.
- Normal progress updates are NOT intervention events and must NOT trigger the callback.
- If cmux is unavailable, skip the flash (best-effort) but still keep the report visible.
EOF
}

_claude_args_have_model() {
    local arg
    for arg in "${claude_args[@]}"; do
        if [[ "$arg" == "--model" || "$arg" == --model=* ]]; then
            return 0
        fi
    done
    return 1
}

# Rename cmux surface if running inside cmux
_cmux_rename() {
    local label="$1"
    if command -v cmux &>/dev/null; then
        local surface_ref
        surface_ref=$(cmux identify --json 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin)['caller']['surface_ref'])" 2>/dev/null)
        if [[ -n "$surface_ref" ]]; then
            cmux rename-tab --surface "$surface_ref" "$label" 2>/dev/null || true
        fi
    fi
}

# ── Default quick-fix route profile ───────────────────────────────────────
# Bare `cld -bq` uses the explicit cld-default quick profile by default, so
# every project gets the same GPT implementation/review/fix-loop slots without
# relying on project-local perspective_policy defaults. The optional
# cld-composer profile remains available via --route-profile cld-composer.
if [[ -z "$route_profile" && -n "$bead_quick_id" ]]; then
    route_profile="cld-default"
fi

if [[ -n "$bead_review_id" ]]; then
    bead_review_id=$(_expand_bead_id "$bead_review_id")
    local bead_review_short=$(_bead_short "$bead_review_id")

    export CLD_BEAD_LINE=cld

    if ! _bead_exists "$bead_review_id"; then
        _abort_missing_bead "$bead_review_id" "Claude"
    fi

    if ! _claude_args_have_model; then
        claude_args=("--model" "opus" "${claude_args[@]}")
    fi

    # ── Narrow read + review-cache tool profile (CL-9knh, fix-cycle 2) ─
    # -br is a spec-readiness reviewer, not an implementer: grant only the
    # canonical local read-only set (Read/Grep/Glob) plus the cognovis-tools
    # MCP read surface the bead-reviewer skill's own tooling contract
    # documents, plus the single typed mutation exception (bead_review_write)
    # for writing metadata.review.
    #
    # Bash is HARD-EXCLUDED via --tools, not merely left out of
    # --allowedTools. An earlier design (fix-cycle 1) granted a single
    # EXACT-match --allowedTools entry, "Bash(cmux trigger-flash --surface
    # ...)", reasoning that exact-match specifiers only authorize that one
    # literal command. Two Opus reviews approved that design as CLEAN, but
    # live `claude --print --permission-mode plan` dry-runs proved it wrong:
    # Claude Code has a plan-mode classifier that independently judges
    # whether a Bash invocation "looks safe" and can silently auto-approve
    # it (permission_denials: []) REGARDLESS of --allowedTools content, as
    # long as Bash is registered as an available tool in the session at
    # all. Confirmed empirically: with
    # --allowedTools="Read,Grep,Glob,Bash(cmux trigger-flash --surface
    # surface:33)" (Bash available but supposedly restricted to one exact
    # literal command), a COMPLETELY DIFFERENT command (`git status`) still
    # executed with zero denial. The exact-match specifier does not gate the
    # classifier's independent judgment once Bash is registered at all. The
    # only verified hard boundary is removing Bash from the built-in tool
    # SET via --tools (which governs tool *registration*, unlike
    # --allowedTools/--disallowedTools, which only govern
    # approval-without-prompting for tools that ARE registered) — confirmed
    # empirically: with --tools=Read,Grep,Glob (no Bash in the set at all),
    # a probe session reported Bash was "not available ... at all", and a
    # --print --output-format json run showed zero Bash tool_use entries and
    # no classifier auto-approval leak. See _coordinator_callback_contract's
    # review branch and Fix 2 below (launcher-side post-exit cmux flash) for
    # how the reviewer now signals the coordinator without any Bash access.
    #
    # --disallowedTools remains defense-in-depth on top of --permission-mode
    # (dontAsk as of CL-9knh iteration 3 — plan was found to categorically
    # block MCP tool execution even for allowlisted tools; see the mode
    # selection block below), --tools, and the allowlist: even if any of
    # those has a bug, general bead mutations and file edits stay blocked.
    #
    # Passed as --flag=value (single argv token, not "--flag" "value" as two
    # tokens) for --tools/--allowedTools/--disallowedTools alike: claude's
    # --tools/--allowedTools/--disallowedTools are all variadic
    # (`<tools...>`) and greedily collect every subsequent non-flag argv
    # element — including a would-be separate value token AND the trailing
    # review prompt after it — splitting each on commas/spaces and
    # misinterpreting prompt words as bogus tool rules (confirmed
    # empirically for --disallowedTools in fix-cycle 1, and reconfirmed for
    # --tools here: the two-token form swallowed the prompt and claude then
    # errored with "Input must be provided ... when using --print"). The
    # "--flag=value" form binds the value to the flag as one token, so the
    # flag's variadic collection has nothing left to swallow and the
    # trailing prompt stays the last positional claude argument.
    local bead_review_tools="Read,Grep,Glob"
    local bead_review_allowed_tools="Read,Grep,Glob,mcp__cognovis-tools__bead_show,mcp__cognovis-tools__bead_search,mcp__cognovis-tools__bead_list,mcp__cognovis-tools__bead_repos,mcp__cognovis-tools__bead_ready,mcp__cognovis-tools__bead_review_write"
    local bead_review_disallowed_tools="Edit,Write,NotebookEdit,mcp__cognovis-tools__bead_create,mcp__cognovis-tools__bead_claim,mcp__cognovis-tools__bead_update,mcp__cognovis-tools__bead_update_notes,mcp__cognovis-tools__bead_close,mcp__cognovis-tools__bead_dep_add,mcp__cognovis-tools__bead_dep_remove,mcp__cognovis-tools__bead_dolt_sync"
    claude_args+=("--tools=${bead_review_tools}" "--allowedTools=${bead_review_allowed_tools}" "--disallowedTools=${bead_review_disallowed_tools}")

    printf '\033]1;%s\033\\' "${bead_review_id}-review"
    printf '\033]2;%s\033\\' "cld-review: $bead_review_id"
    _cmux_rename "${bead_review_short}-review"

    local review_prompt="Bead ID: $bead_review_id. Use the bead-reviewer skill to perform a CRITICAL
factory-ready spec / autonomous-readiness review of this bead. Review the bead
SPECIFICATION and readiness ONLY. Do NOT implement, do NOT create a worktree, do NOT
run session-close, do NOT review implementation diffs. Emit the bead-reviewer verdict
as the terminal state."

    if _has_coordinator_callback; then
        review_prompt+="

$(_coordinator_callback_contract review)"
    fi

    claude_args+=("$review_prompt")
fi

if [[ -n "$bead_id" ]]; then
    bead_id=$(_expand_bead_id "$bead_id")
    local bead_short=$(_bead_short "$bead_id")

    # Export CLD_BEAD_LINE=cld so the bead-orchestrator agent resolves
    # impl/reviewer models from perspective_policy.cld in
    # .agents/orchestrator-config.yml. Symmetric to cdx's CLD_BEAD_LINE=cdx
    # export for the cdx-line entry points.
    export CLD_BEAD_LINE=cld

    # Export CLD_ROUTE_PROFILE so phase0-claim.py can resolve execution_plan
    # from the named route profile (CL-iye.1).
    if [[ -n "$route_profile" ]]; then
        export CLD_ROUTE_PROFILE="$route_profile"
    fi

    if ! _bead_exists "$bead_id"; then
        _abort_missing_bead "$bead_id" "Claude"
    fi

    # ── Epic guard: refuse parent beads (has children) ────────────
    local _child_count
    _child_count=$(_bead_child_count "$bead_id")
    if [[ "$_child_count" -gt 0 ]]; then
        echo -e "\033[0;31m✗ ${bead_id} has ${_child_count} children.\033[0m" >&2
        echo "  Waves must be started manually using the wave skills with cmux panes." >&2
        echo "  To work on a single child, use its own ID with cld -b." >&2
        exit 2
    fi

    # ── Claim gate: refuse if bead is already in_progress or closed ──
    local _STATUS
    _STATUS=$(_bead_status "$bead_id" || echo "")
    if [[ "$_STATUS" == "in_progress" || "$_STATUS" == "closed" ]]; then
        echo -e "\033[0;31m✗ ${bead_id} is ${_STATUS}.\033[0m" >&2
        echo "  Cannot launch: bead is already ${_STATUS}." >&2
        if [[ "$_STATUS" == "in_progress" ]]; then
            echo "  To take over: bd update ${bead_id} --status=open" >&2
        fi
        exit 2
    fi

    # ── Sync: pull latest git + dolt state before worktree creation ──
    echo -e "\033[0;36m⟳ Syncing git and dolt before worktree creation...\033[0m"
    git fetch origin 2>/dev/null && git pull --no-rebase 2>/dev/null || echo -e "\033[0;33m⚠ git pull failed (non-fatal, continuing)\033[0m"
    "${BD_BIN}" dolt pull 2>/dev/null || echo -e "\033[0;33m⚠ bd dolt pull failed (non-fatal, continuing)\033[0m"

    # ── Worktree isolation via Claude Code native --worktree ──────
    local worktree_name="bead-${bead_id}"
    claude_args+=("--worktree" "$worktree_name")
    claude_args+=("--agent" "bead-orchestrator")
    # ── Force full plugin registry in the worktree session ────────
    # CCP-9xy: guarantees core:session-close is spawnable at Phase 16 handoff,
    # even if a project-level .claude/settings overrides setting-sources.
    claude_args+=("--setting-sources" "user,project,local")

    # ── Set terminal tab title + cmux pane name ──────────────────
    printf '\033]1;%s\033\\' "$bead_id"
    printf '\033]2;%s\033\\' "cld: $bead_id"
    _cmux_rename "${bead_short}-impl"

    # ── Derive portless namespace from bead prefix + number ───────
    local bead_ns=""
    if [[ -n "$bead_prefix" ]]; then
        local bead_num="${bead_id##*-}"
        bead_ns="${bead_prefix}-${bead_num}"
    fi

    # Execute the COMPLETE workflow (phases 0-16 including Phase 16 session-close).
    # Never stop at "Phase 0-5" — that scope does not exist for the full orchestrator.
    local prompt="Bead ID: $bead_id. Execute the full orchestration workflow end-to-end: Phase 0 through Phase 16 (session-close). Do not stop after any intermediate phase. Session-close auto-triggers in Phase 16."

    if [[ -n "$bead_ns" ]]; then
        prompt+=" Portless namespace: $bead_ns (use as namespace when starting dev servers, e.g. for portless-based setups)."
    fi

    if [[ -n "$route_profile" ]]; then
        prompt+=" Route profile: $route_profile (pass --route-profile $route_profile to phase0-claim.py)."
    fi

    if [[ -n "$force_tier" ]]; then
        prompt+=" Force tier: $force_tier (pass --force-tier $force_tier to phase0-claim.py)."
    fi

    if _has_coordinator_callback; then
        prompt+="

$(_coordinator_callback_contract impl)"
    fi

    claude_args+=("$prompt")
fi

if [[ -n "$bead_quick_id" ]]; then
    bead_quick_id=$(_expand_bead_id "$bead_quick_id")
    local bead_quick_short=$(_bead_short "$bead_quick_id")

    # Export CLD_BEAD_LINE=cld so the quick-fix agent resolves the impl model
    # from perspective_policy.cld.tier_impl_override.quick (= gpt-5.4-mini in
    # the default user-global config, routed via codex-impl.py). Symmetric to
    # cdx -bq's CLD_BEAD_LINE=cdx export.
    export CLD_BEAD_LINE=cld

    # Export CLD_ROUTE_PROFILE so phase0-claim.py resolves the quick execution_plan
    # from the named route profile. The -bq path previously ignored route profiles
    # entirely; this makes the cld-default default (and explicit --route-profile)
    # take effect for quick-fix too.
    if [[ -n "$route_profile" ]]; then
        export CLD_ROUTE_PROFILE="$route_profile"
    fi

    if ! _bead_exists "$bead_quick_id"; then
        _abort_missing_bead "$bead_quick_id" "Claude"
    fi

    # ── Claim gate: refuse if bead is already in_progress or closed ──
    local _QF_STATUS
    _QF_STATUS=$(_bead_status "$bead_quick_id" || echo "")
    if [[ "$_QF_STATUS" == "in_progress" || "$_QF_STATUS" == "closed" ]]; then
        echo -e "\033[0;31m✗ ${bead_quick_id} is ${_QF_STATUS}.\033[0m" >&2
        echo "  Cannot launch: bead is already ${_QF_STATUS}." >&2
        if [[ "$_QF_STATUS" == "in_progress" ]]; then
            echo "  To take over: bd update ${bead_quick_id} --status=open" >&2
        fi
        exit 2
    fi

    # ── Sync: pull latest git + dolt state before worktree creation ──
    echo -e "\033[0;36m⟳ Syncing git and dolt before worktree creation...\033[0m"
    git fetch origin 2>/dev/null && git pull --no-rebase 2>/dev/null || echo -e "\033[0;33m⚠ git pull failed (non-fatal, continuing)\033[0m"
    "${BD_BIN}" dolt pull 2>/dev/null || echo -e "\033[0;33m⚠ bd dolt pull failed (non-fatal, continuing)\033[0m"

    # ── Worktree isolation via Claude Code native --worktree ──────
    local worktree_name="bead-${bead_quick_id}"
    claude_args+=("--worktree" "$worktree_name")
    claude_args+=("--agent" "quick-fix")
    # ── Force full plugin registry in the worktree session ────────
    # CCP-9xy: guarantees core:session-close is spawnable at Phase 5 handoff,
    # even if a project-level .claude/settings overrides setting-sources.
    claude_args+=("--setting-sources" "user,project,local")

    # ── Set terminal tab title + cmux pane name ──────────────────
    printf '\033]1;%s\033\\' "$bead_quick_id"
    printf '\033]2;%s\033\\' "cld-qf: $bead_quick_id"
    _cmux_rename "${bead_quick_short}-qf"

    # ── Derive portless namespace from bead prefix + number ───────
    local bead_ns=""
    if [[ -n "$bead_prefix" ]]; then
        local bead_num="${bead_quick_id##*-}"
        bead_ns="${bead_prefix}-${bead_num}"
    fi

    # Execute the COMPLETE quick-fix workflow (phases 0-5 including Phase 5 session-close).
    local prompt="Bead ID: $bead_quick_id. Execute quick-fix workflow end-to-end: Phase 0 through Phase 5 (session-close). Do not stop after any intermediate phase. Session-close auto-triggers in Phase 5."

    if [[ -n "$bead_ns" ]]; then
        prompt+=" Portless namespace: $bead_ns (use as namespace when starting dev servers, e.g. for portless-based setups)."
    fi

    if _has_coordinator_callback; then
        prompt+="

$(_coordinator_callback_contract impl)"
    fi

    claude_args+=("$prompt")
fi

if [[ -n "$plan_label" ]]; then
    claude_args+=("/plan --label $plan_label")
fi

# ── Launch claude ────────────────────────────────────────────────
# Ensure cmux-shim is used for Stop hook notifications (prevents cmux wrapper override)
export CMUX_BUNDLED_CLI_PATH="${HOME}/.claude/scripts/cmux-shim.sh"

# ── -br (bead-review) launcher-side post-exit cmux flash (CL-9knh) ────
# The -br tool profile hard-excludes Bash (see the tool-profile block
# above), so a review session can no longer run `cmux trigger-flash` itself
# to signal the coordinator on terminal state. Responsibility for that
# single signal moves here, into the launcher's own (unrestricted) shell
# context, run AFTER the claude subprocess exits. This requires running
# claude as a foreground child instead of `exec`-replacing this process —
# `exec` never returns, so nothing could run after it — while every other
# mode (-b, -bq, plain passthrough) keeps the original `exec` behavior
# unchanged (process replacement, signal forwarding) since they have no
# post-exit work to do.
#
# Known, deliberate scope reduction: the OLD in-session design had two
# distinct triggers (mid-session "blocking question" flash + a separate
# terminal-verdict flash). This launcher-side flash collapses both into ONE
# signal that fires whenever the claude subprocess exits, for any reason
# (clean verdict, error, or the model ending its turn on a blocking
# question) — the coordinator is expected to inspect the pane's visible
# output to distinguish those cases. Building a live mid-session signaling
# channel for a Bash-less session is out of scope here (would require
# re-granting some capability); track as a future "parameterized callback
# lifecycle" bead if ever needed.
if [[ -n "$bead_review_id" ]]; then
    "${CLAUDE_BIN}" "${claude_args[@]}"
    _claude_exit=$?
    if _has_coordinator_callback && command -v cmux &>/dev/null; then
        # $coordinator_surface is already regex-validated
        # (^surface:[0-9]+$, see the validation block near the top of this
        # script) before this point is ever reached, so its literal value is
        # known and injection-free. Best-effort: a failed/unavailable cmux
        # must not affect this launcher's own exit code.
        cmux trigger-flash --surface "${coordinator_surface}" 2>/dev/null || true
    fi
    exit "${_claude_exit}"
fi

exec "${CLAUDE_BIN}" "${claude_args[@]}"
