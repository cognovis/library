#!/usr/bin/env zsh
# cdx - Codex launcher with beads workflow integration
#
# Usage: cdx [wrapper-flags] [codex-args...]
#        cdx -h | --help        Show wrapper flag help, then fall through to codex --help
#
# Wrapper flags (not passed to codex):
#   --no-full-auto  → Launch codex without the default --full-auto wrapper
#   --tui           → For cdx -b, force interactive Codex TUI mode
#   --exec          → For cdx -b, force non-interactive codex exec mode
#   -b, --bead ID   → launch Codex workflow orchestrator for the given bead ID
#                     (Codex remains top-level; helpers run inside the workflow)
#   -bq, --bead-quick ID → launch with quick-fix prompt for XS/S beads (bug, chore, task)
#   -br, --bead-review ID → cmux-review mode (warns if Codex equivalent missing)
#   --route-profile NAME → select named route profile (exports CLD_ROUTE_PROFILE)
#
# Note: Codex has no --bead flag equivalent. cdx bead modes synthesize bead
#       context and pass it to Codex (TUI when interactive, exec for
#       automation). Set CDX_BEAD_WORKFLOW=python to run the deterministic
#       helper directly for smoke tests or CI.

set -euo pipefail

CODEX_BIN="${CODEX_BIN:-$(command -v codex 2>/dev/null)}"
if [[ -z "${CODEX_BIN}" ]]; then
    echo "ERROR: codex not found in PATH. Install Codex first: https://github.com/openai/codex"
    exit 1
fi
GIT_BIN="${GIT_BIN:-$(command -v git 2>/dev/null)}"
CDX_SCRIPT_DIR="${0:A:h}"
COMPACT_CONTEXT_SCRIPT="${CDX_COMPACT_CONTEXT_SCRIPT:-${CDX_SCRIPT_DIR:h}/scripts/compact-bead-context.py}"
QUICK_CURSOR_DISPATCH_SCRIPT="${CDX_QUICK_CURSOR_DISPATCH_SCRIPT:-${CDX_SCRIPT_DIR:h}/scripts/cdx-quick-cursor-dispatch.py}"
FULL_BEAD_WORKFLOW_SCRIPT="${CDX_BEAD_WORKFLOW_SCRIPT:-${CDX_SCRIPT_DIR:h}/scripts/cdx-bead-workflow.py}"
CODEX_JSONL_FILTER_SCRIPT="${CDX_JSONL_FILTER_SCRIPT:-${CDX_SCRIPT_DIR:h}/scripts/filter-codex-jsonl.py}"

# Resolve bd lazily to avoid set -e exit when bd is not installed (only needed for bead modes)
BD_BIN="${BD_BIN:-}"
if [[ -z "${BD_BIN}" ]]; then
    BD_BIN="$(command -v bd 2>/dev/null || true)"
fi

fetch_bead_context() {
    local bead_id="$1"
    local bead_json=""

    bead_json=$("${BD_BIN}" show "${bead_id}" --json 2>/dev/null) || return 1

    if [[ -f "$COMPACT_CONTEXT_SCRIPT" ]] && command -v uv >/dev/null 2>&1; then
        if printf '%s' "$bead_json" | uv run python "$COMPACT_CONTEXT_SCRIPT" 2>/dev/null; then
            return 0
        fi
    fi

    "${BD_BIN}" show "${bead_id}" 2>/dev/null
}

abort_missing_bead() {
    local bead_id="$1"

    echo "ERROR: Bead ${bead_id} was not found in this repository (${PWD})." >&2
    echo "Aborting before launching Codex. Run cdx from the project that owns the bead." >&2
    exit 2
}

# ── Parse wrapper flags ──────────────────────────────────────────

use_full_auto=true
show_help=false
bead_id=""
bead_quick_id=""
bead_review_id=""
route_profile=""
codex_bead_mode="${CDX_BEAD_CODEX_MODE:-auto}"
codex_args=()
compact_output_contract="Default output mode is compact. Emit stable lifecycle markers and concise summaries only.
- Do not paste full diffs, full file bodies, full search hits, or long command output unless needed to diagnose a blocking failure.
- Use targeted searches with bounded output and summarize results; write large evidence to files and report the path plus a short tail.
- Surface leaf dispatch with grepable markers such as LEAF_DISPATCH, CURSOR_AGENT_START, and CURSOR_AGENT_EXIT."

run_codex_exec() {
    local prompt="$1"
    local worktree_dir="$2"

    if [[ "${CLD_COMPACT_OUTPUT:-1}" == "1" && -f "$CODEX_JSONL_FILTER_SCRIPT" ]] && command -v uv >/dev/null 2>&1; then
        set +e
        "${CODEX_BIN}" exec --json --dangerously-bypass-approvals-and-sandbox -C "$worktree_dir" "${codex_args[@]}" "${prompt}" \
            | uv run python "$CODEX_JSONL_FILTER_SCRIPT"
        local -a pipe_status=("${pipestatus[@]}")
        set -e
        if (( pipe_status[1] != 0 )); then
            return "${pipe_status[1]}"
        fi
        return "${pipe_status[2]}"
    fi

    exec "${CODEX_BIN}" exec --dangerously-bypass-approvals-and-sandbox -C "$worktree_dir" "${codex_args[@]}" "${prompt}"
}

run_codex_tui() {
    local prompt="$1"
    local worktree_dir="$2"

    exec "${CODEX_BIN}" --dangerously-bypass-approvals-and-sandbox -C "$worktree_dir" "${codex_args[@]}" "${prompt}"
}

sanitize_name() {
    echo "$1" | tr -cs 'A-Za-z0-9_-' '-' | sed 's/^-*//;s/-*$//'
}

ensure_worktree_excluded() {
    local repo_root="$1"
    local exclude_file="$repo_root/.git/info/exclude"

    if [[ ! -d "$repo_root/.git" ]]; then
        return 0
    fi
    mkdir -p "$repo_root/.git/info"
    if [[ ! -f "$exclude_file" ]] || ! grep -qxF ".claude/worktrees/" "$exclude_file"; then
        printf "\n# cdx/cld bead worktrees\n.claude/worktrees/\n" >> "$exclude_file"
    fi
}

ensure_bead_worktree() {
    local bead="$1"

    if [[ -z "${GIT_BIN}" ]]; then
        echo "ERROR: git not found in PATH. Cannot create bead worktree." >&2
        return 1
    fi

    local repo_root
    repo_root=$("${GIT_BIN}" rev-parse --show-toplevel 2>/dev/null) || {
        echo "ERROR: cdx -b must run inside a git repository." >&2
        return 1
    }

    local safe_bead
    safe_bead="$(sanitize_name "$bead")"
    local worktree_root="${CDX_WORKTREE_ROOT:-${repo_root}/.claude/worktrees}"
    local worktree_dir="${worktree_root}/bead-${safe_bead}"
    local branch_name="${CDX_WORKTREE_BRANCH_PREFIX:-worktree-bead-}${safe_bead}"

    if "${GIT_BIN}" worktree list --porcelain 2>/dev/null | grep -Fxq "worktree ${worktree_dir}"; then
        printf '%s\n' "$worktree_dir"
        return 0
    fi

    if [[ -e "$worktree_dir" ]]; then
        echo "ERROR: worktree path exists but is not registered: $worktree_dir" >&2
        return 1
    fi

    mkdir -p "$worktree_root"
    ensure_worktree_excluded "$repo_root"

    if "${GIT_BIN}" show-ref --verify --quiet "refs/heads/${branch_name}"; then
        "${GIT_BIN}" worktree add "$worktree_dir" "$branch_name" >/dev/null
    else
        "${GIT_BIN}" worktree add -b "$branch_name" "$worktree_dir" HEAD >/dev/null
    fi
    printf '%s\n' "$worktree_dir"
}

resolve_codex_bead_mode() {
    local mode="$1"

    case "$mode" in
        auto|"")
            if [[ -t 0 && -t 1 ]]; then
                printf '%s\n' "tui"
            else
                printf '%s\n' "exec"
            fi
            ;;
        tui|exec)
            printf '%s\n' "$mode"
            ;;
        *)
            echo "ERROR: unsupported cdx bead mode '$mode' (use auto, tui, or exec)" >&2
            return 2
            ;;
    esac
}

while (( $# > 0 )); do
    case "$1" in
        -h|--help)
            show_help=true
            shift
            ;;
        --no-full-auto)
            use_full_auto=false
            shift
            ;;
        --tui)
            codex_bead_mode="tui"
            shift
            ;;
        --exec)
            codex_bead_mode="exec"
            shift
            ;;
        -b|--bead)
            bead_id="$2"
            shift 2
            ;;
        -bq|--bead-quick)
            bead_quick_id="$2"
            shift 2
            ;;
        -br|--bead-review)
            bead_review_id="$2"
            shift 2
            ;;
        --route-profile)
            route_profile="$2"
            shift 2
            ;;
        *)
            codex_args+=("$1")
            shift
            ;;
    esac
done

# ── Help ──────────────────────────────────────────────────────────

if ${show_help}; then
    cat <<'HELP'
cdx - Codex launcher with beads workflow integration

Usage: cdx [wrapper-flags] [codex-args...]

Wrapper flags (consumed by cdx, not passed to codex):

  Bead workflows:
    -b,  --bead ID              Launch Codex workflow orchestrator for single bead
                                (Codex top-level, deterministic helpers inside)
    -bq, --bead-quick ID        Launch quick-fix prompt for XS/S beads
    -br, --bead-review ID       Review mode (warns: Codex has no cmux-review equivalent)
         --route-profile NAME    Select named route profile (exports CLD_ROUTE_PROFILE)
                                Profiles: cld-default, cdx-default, cdx-composer

  Session:
         --no-full-auto          Launch codex without the default --full-auto wrapper
         --tui                   For cdx -b, force interactive Codex TUI mode
         --exec                  For cdx -b, force non-interactive codex exec mode
    -h,  --help                  Show this help, then codex --help

────────────────────────────────────────────────────────────
Note: Codex has no --bead flag equivalent. cdx bead modes synthesize bead
context and pass it to Codex (TUI when interactive, exec for automation).
Set CDX_BEAD_WORKFLOW=python to run the deterministic helper directly for
smoke tests or CI.
────────────────────────────────────────────────────────────
Forwarding to 'codex --help':
HELP
    exec "${CODEX_BIN}" --help
fi

# ── Bead orchestrator mode: cdx -b <id> ─────────────────────────

if [[ -n "$bead_id" ]]; then
    if [[ -z "${BD_BIN}" ]]; then
        echo "ERROR: bd not found in PATH. Install the beads CLI first."
        exit 1
    fi

    bead_context=$(fetch_bead_context "${bead_id}") || {
        abort_missing_bead "${bead_id}"
    }

    # Export CLD_BEAD_LINE=cdx so any downstream tooling spawned from this
    # codex session (codex-impl.py, codex-exec.py, nested Claude invocations)
    # sees the cdx line and resolves impl/reviewer models from
    # perspective_policy.cdx in .agents/orchestrator-config.yml.
    export CLD_BEAD_LINE=cdx

    # Export CLD_ROUTE_PROFILE when --route-profile is set (CL-iye.1).
    route_profile="${route_profile:-${CDX_DEFAULT_ROUTE_PROFILE:-cdx-composer}}"
    if [[ -n "$route_profile" ]]; then
        export CLD_ROUTE_PROFILE="$route_profile"
    fi
    export CLD_COMPACT_OUTPUT="${CLD_COMPACT_OUTPUT:-1}"

    workflow_mode="${CDX_BEAD_WORKFLOW:-codex}"
    if [[ "$workflow_mode" == "1" || "$workflow_mode" == "python" || "$workflow_mode" == "deterministic" ]]; then
        if [[ ! -f "$FULL_BEAD_WORKFLOW_SCRIPT" ]]; then
            echo "ERROR: cdx bead workflow helper not found: $FULL_BEAD_WORKFLOW_SCRIPT" >&2
            exit 1
        fi
        if (( ${#codex_args[@]} > 0 )); then
            echo "WARNING: deterministic cdx bead workflow ignores Codex CLI args: ${codex_args[*]}" >&2
        fi
        printf '%s' "$bead_context" | uv run python "$FULL_BEAD_WORKFLOW_SCRIPT" \
            "$bead_id" --route-profile "$route_profile"
        exit $?
    fi
    if [[ "$workflow_mode" != "0" && "$workflow_mode" != "codex" && "$workflow_mode" != "agent" ]]; then
        echo "ERROR: unsupported CDX_BEAD_WORKFLOW=$workflow_mode (use codex or python)" >&2
        exit 2
    fi

    worktree_dir="$(ensure_bead_worktree "$bead_id")" || exit $?
    resolved_codex_bead_mode="$(resolve_codex_bead_mode "$codex_bead_mode")" || exit $?

    prompt="You are the active Codex workflow orchestrator for bead ${bead_id}. Run the full bead workflow end-to-end: Phase 0 through Phase 16, including session-close. Do not stop after any intermediate phase.

Own orchestration in this current Codex session. Do not invoke the high-level beads dispatcher, and do not spawn or dispatch a nested top-level orchestrator for this bead. Only use subagents/skills for bounded workflow leaves that are not the top-level orchestrator, such as bead-reviewer refresh, architecture review, adversarial review, verification, or session-close.

Use deterministic helpers under the beads runtime for claim/routing, context, scope checks, slot dispatch, metrics, and workflow events. If Phase 0 reports BEAD_REVIEWER_REFRESH_REQUIRED, run the bead-reviewer as a bounded subagent/skill refresh, then retry Phase 0 once. Do not implement inline until the workflow reaches the full.implementation slot; route-profile slots may dispatch another implementer harness such as Cursor/Composer.

Do NOT run \`bd prime\` (the SessionStart hook already emitted the workflow primer) — the bead context and workflow contract above are sufficient.

Worktree: ${worktree_dir}

## Compact Output Contract

${compact_output_contract}

## Bead Context

${bead_context}"

    if [[ -n "$route_profile" ]]; then
        prompt+=" Route profile: $route_profile (pass --route-profile $route_profile to phase0-claim.py)."
    fi

    case "$resolved_codex_bead_mode" in
        tui)
            run_codex_tui "${prompt}" "$worktree_dir"
            ;;
        exec)
            run_codex_exec "${prompt}" "$worktree_dir"
            ;;
    esac
    exit $?
fi

# ── Quick-fix mode: cdx -bq <id> ────────────────────────────────

if [[ -n "$bead_quick_id" ]]; then
    if [[ -z "${BD_BIN}" ]]; then
        echo "ERROR: bd not found in PATH. Install the beads CLI first."
        exit 1
    fi

    bead_context=$(fetch_bead_context "${bead_quick_id}") || {
        abort_missing_bead "${bead_quick_id}"
    }

    # Export CLD_BEAD_LINE=cdx so downstream tools (codex-impl.py, any nested
    # Claude Agent dispatch) resolve impl model from perspective_policy.cdx
    # in .agents/orchestrator-config.yml (= claude-haiku-4-5 for quick tier
    # in the default user-global config).
    export CLD_BEAD_LINE=cdx

    # Export CLD_ROUTE_PROFILE when --route-profile is set (CL-iye.1).
    if [[ -n "$route_profile" ]]; then
        export CLD_ROUTE_PROFILE="$route_profile"
    fi
    export CLD_COMPACT_OUTPUT="${CLD_COMPACT_OUTPUT:-1}"

    if [[ "$route_profile" == "cdx-composer" ]]; then
        if [[ ! -f "$QUICK_CURSOR_DISPATCH_SCRIPT" ]]; then
            echo "ERROR: cdx-composer quick dispatch helper not found: $QUICK_CURSOR_DISPATCH_SCRIPT" >&2
            exit 1
        fi
        if (( ${#codex_args[@]} > 0 )); then
            echo "WARNING: cdx-composer quick dispatch uses cursor-impl directly; Codex CLI args are ignored: ${codex_args[*]}" >&2
        fi
        printf '%s' "$bead_context" | uv run python "$QUICK_CURSOR_DISPATCH_SCRIPT" \
            "$bead_quick_id" --route-profile "$route_profile"
        exit $?
    fi

    prompt="Bead ID: ${bead_quick_id}. Execute quick-fix workflow end-to-end: Phase 0 through Phase 5 (session-close). Do not stop after any intermediate phase. Session-close auto-triggers in Phase 5. Do NOT run \`bd prime\` (the SessionStart hook already emitted the workflow primer).

## Compact Output Contract

${compact_output_contract}

## Bead Context

${bead_context}"

    if [[ -n "$route_profile" ]]; then
        prompt+=" Route profile: $route_profile (pass --route-profile $route_profile to phase0-claim.py)."
    fi

    run_codex_exec "${prompt}"
    exit $?
fi

# ── Review mode: cdx -br <id> ───────────────────────────────────

if [[ -n "$bead_review_id" ]]; then
    echo "WARNING: cdx -br (review mode) has no full cmux-review equivalent in Codex." >&2
    echo "  Codex has no multi-pane cmux integration. Launching basic code review instead." >&2
    echo "  For full review workflow, use: cld -br ${bead_review_id}" >&2
    echo ""

    if [[ -z "${BD_BIN}" ]]; then
        echo "ERROR: bd not found in PATH. Install the beads CLI first."
        exit 1
    fi

    bead_context=$("${BD_BIN}" show "${bead_review_id}" 2>/dev/null) || {
        echo "ERROR: Could not fetch bead context for ${bead_review_id}. Is the bead ID correct?"
        exit 1
    }

    # cdx-line review mode — set CLD_BEAD_LINE=cdx for downstream tools.
    export CLD_BEAD_LINE=cdx

    prompt="Review the implementation for bead ${bead_review_id}. Check all acceptance criteria are met. Run 'codex exec review' patterns to validate code quality.

## Bead Context

${bead_context}"

    exec "${CODEX_BIN}" exec --dangerously-bypass-approvals-and-sandbox "${codex_args[@]}" "${prompt}"
fi

# ── Default: plain Codex launch ─────────────────────────────────

if ${use_full_auto}; then
    # Full equivalent of "cld --dangerously-skip-permissions": no approval prompts AND
    # no sandbox. The previous workspace-write sandbox blocked paths outside the workdir
    # (e.g. ~/.cache/uv) and caused recurring "permission denied" / "operation not
    # permitted" failures. Safeguarding is delegated to dcg via ~/.codex/hooks.json
    # (PreToolUse Bash hook). Use --no-full-auto to opt back into Codex's default sandbox.
    # See: https://developers.openai.com/codex/agent-approvals-security
    exec "${CODEX_BIN}" --dangerously-bypass-approvals-and-sandbox "${codex_args[@]}"
else
    exec "${CODEX_BIN}" "${codex_args[@]}"
fi
